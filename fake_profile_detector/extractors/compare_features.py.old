import glob
import os
import time
from datetime import datetime

import numpy as np
import pandas as pd
from sklearn.ensemble import RandomForestClassifier
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, classification_report
from sklearn.model_selection import train_test_split
from sklearn.naive_bayes import GaussianNB
from sklearn.svm import SVC
from tqdm import tqdm

from fake_profile_detector.configs.general import BASE_DIR, SAVE_DIR
from fake_profile_detector.feature_extractors import FeatureExtractor


def load_image_dataset():
    dataset_dir = os.path.join(BASE_DIR, "x")

    if not os.path.exists(dataset_dir):
        raise ValueError(f"Dataset directory not found: {dataset_dir}")

    image_extensions = ["*.jpg", "*.jpeg", "*.png"]
    image_files = []

    for ext in image_extensions:
        image_files.extend(glob.glob(os.path.join(dataset_dir, ext)))
        image_files.extend(glob.glob(os.path.join(dataset_dir, ext.upper())))

    if not image_files:
        raise ValueError(f"No images found in {dataset_dir}")

    labels = []
    valid_files = []

    for image_path in image_files:
        filename = os.path.basename(image_path)
        try:
            # Extract label from filename (format: "xxxxx_y.png")
            name_without_ext = os.path.splitext(filename)[0]  # Remove extension
            parts = name_without_ext.split("_")

            if len(parts) >= 2:
                label = int(parts[-1])  # Take the last part as label
                # Keep original labels: 0=bot, 1=cyborg, 2=real, 4=verified
                # Note: We keep 4 as is, or you can map it to 3 if needed
                labels.append(label)
                valid_files.append(image_path)
            else:
                print(f"Skipping file with invalid format: {filename}")

        except (ValueError, IndexError):
            print(f"Skipping file with invalid format: {filename}")

    labels = np.array(labels)

    print(f"Loaded {len(valid_files)} images")
    print(f"Label distribution:")
    unique_labels, counts = np.unique(labels, return_counts=True)
    label_names = {0: "bot", 1: "cyborg", 2: "real", 4: "verified"}
    for label, count in zip(unique_labels, counts):
        label_name = label_names.get(label, f"unknown_{label}")
        print(f"  Class {label} ({label_name}): {count} images")

    return valid_files, labels


def evaluate_features(X, y, feature_name):
    print(f"\nEvaluating {feature_name}...")

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.3, random_state=42, stratify=y
    )

    classifiers = {
        "Naive Bayes": GaussianNB(),
        "Random Forest": RandomForestClassifier(n_estimators=50, random_state=42),
    }

    results = {}

    for clf_name, classifier in classifiers.items():
        print(f"  Training {clf_name}...")
        start_time = time.time()

        try:
            classifier.fit(X_train, y_train)
            y_pred = classifier.predict(X_test)
            accuracy = accuracy_score(y_test, y_pred)
            train_time = time.time() - start_time

            results[clf_name] = {
                "accuracy": accuracy,
                "train_time": train_time,
                "feature_dim": X.shape[1],
            }

            print(f"    Accuracy: {accuracy:.4f}, Time: {train_time:.2f}s")

        except Exception as e:
            print(f"    Error with {clf_name}: {e}")
            results[clf_name] = {
                "accuracy": 0.0,
                "train_time": 0.0,
                "feature_dim": X.shape[1],
            }

    return results


def main():
    image_paths, labels = load_image_dataset()

    feature_methods = [
        ("Raw Pixels", "raw_pixel", False),
        ("Raw Pixels + PCA", "raw_pixel", True),
        ("HOG", "hog", False),
        ("HOG + PCA", "hog", True),
        ("SIFT", "sift", False),
        ("SIFT + PCA", "sift", True),
        ("SURF", "surf", False),
        ("SURF + PCA", "surf", True),
    ]

    all_results = []

    for method_name, feature_type, use_pca in feature_methods:
        print(f"\n{'='*60}")
        print(f"Processing: {method_name}")
        print(f"{'='*60}")

        try:
            # Create feature extractor
            extractor = FeatureExtractor(
                feature_type=feature_type,
                apply_pca=use_pca,
                pca_components=None,  # Use 95% variance
            )

            # Extract features
            start_time = time.time()
            X, valid_indices = extractor.fit_transform(image_paths)
            extraction_time = time.time() - start_time

            # Filter labels for valid images
            y_valid = labels[valid_indices]

            print(f"Feature extraction completed in {extraction_time:.2f}s")
            print(f"Feature shape: {X.shape}")

            # Evaluate features
            evaluation_results = evaluate_features(X, y_valid, method_name)

            # Store results
            for clf_name, metrics in evaluation_results.items():
                all_results.append(
                    {
                        "Feature_Method": method_name,
                        "Classifier": clf_name,
                        "Accuracy": metrics["accuracy"],
                        "Training_Time": metrics["train_time"],
                        "Feature_Dimension": metrics["feature_dim"],
                        "Extraction_Time": extraction_time,
                    }
                )

        except Exception as e:
            print(f"Error processing {method_name}: {e}")
            continue

    results_df = pd.DataFrame(all_results)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    results_file = os.path.join(SAVE_DIR, "logs", f"feature_comparison_{timestamp}.csv")
    os.makedirs(os.path.dirname(results_file), exist_ok=True)

    results_df.to_csv(results_file, index=False)
    print(f"\nResults saved to: {results_file}")

    print("\n" + "=" * 80)
    print("FEATURE EXTRACTION COMPARISON SUMMARY")
    print("=" * 80)

    best_accuracies = (
        results_df.groupby("Feature_Method")["Accuracy"]
        .max()
        .sort_values(ascending=False)
    )
    print("\nBest Accuracy by Feature Method:")
    for method, accuracy in best_accuracies.items():
        print(f"  {method:20}: {accuracy:.4f}")

    best_by_classifier = (
        results_df.groupby("Classifier")["Accuracy"].max().sort_values(ascending=False)
    )
    print("\nBest Accuracy by Classifier:")
    for classifier, accuracy in best_by_classifier.items():
        print(f"  {classifier:20}: {accuracy:.4f}")

    print("\nFeature Dimensions:")
    feature_dims = results_df.groupby("Feature_Method")["Feature_Dimension"].first()
    for method, dim in feature_dims.items():
        print(f"  {method:20}: {dim:6d}")

    print("\nFeature Extraction Times:")
    extraction_times = results_df.groupby("Feature_Method")["Extraction_Time"].first()
    for method, time_taken in extraction_times.items():
        print(f"  {method:20}: {time_taken:6.2f}s")

    return results_df


if __name__ == "__main__":
    main()
