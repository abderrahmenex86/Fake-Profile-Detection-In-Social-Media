import glob
import os
import sys

import pandas as pd

from fake_profile_detector.compare_features import main as compare_main
from fake_profile_detector.configs.general import SAVE_DIR
from fake_profile_detector.visualize_comparison import (
    create_summary_table, plot_feature_comparison)


def main():
    print("Starting Feature Extraction Comparison...")
    print("=" * 60)

    print("Step 1: Extracting features and comparing methods...")
    try:
        results_df = compare_main()
        print("✓ Feature comparison completed successfully!")
    except Exception as e:
        print(f"✗ Error in feature comparison: {e}")
        return

    print("\nStep 2: Creating visualizations...")
    try:
        results_files = glob.glob(
            os.path.join(SAVE_DIR, "logs", "feature_comparison_*.csv")
        )
        if results_files:
            latest_file = max(results_files, key=os.path.getmtime)
            results_df = pd.read_csv(latest_file)

            plot_feature_comparison(results_df, save_dir=os.path.dirname(latest_file))
            create_summary_table(results_df)
            print("✓ Visualizations created successfully!")
        else:
            print("✗ No results file found for visualization")
    except Exception as e:
        print(f"✗ Error creating visualizations: {e}")

    print("\n" + "=" * 60)
    print("Feature comparison pipeline completed!")


if __name__ == "__main__":
    main()
